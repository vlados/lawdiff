            "sort_order": 4,
            "has_in_links": false,
            "is_orphaned": false,
            "text_markdown": "###  ПРЕХОДНА РАЗПОРЕДБА",
            "children": [
                {
                    "path": "ПРЕХОДНАРАЗПОРЕДБА/§1",
