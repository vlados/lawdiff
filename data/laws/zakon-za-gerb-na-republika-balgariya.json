            "has_in_links": false,
            "is_orphaned": false,
            "text_markdown": "###  ЗАКЛЮЧИТЕЛНА РАЗПОРЕДБА",
            "children": [
                {
                    "path": "ЗАКЛЮЧИТЕЛНАРАЗПОРЕДБА/ПАРАГРАФЕДИНСТВЕН",
