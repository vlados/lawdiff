            "sort_order": 5,
            "has_in_links": false,
            "is_orphaned": false,
            "text_markdown": "### ЗАКЛЮЧИТЕЛНИ РАЗПОРЕДБИ",
            "children": [
                {
                    "path": "ЗАКЛЮЧИТЕЛНИ/§1",
                    "p_id": 53499063,
                    "caption": "§ 1",
                    "node_type": "transitional_paragraph",
