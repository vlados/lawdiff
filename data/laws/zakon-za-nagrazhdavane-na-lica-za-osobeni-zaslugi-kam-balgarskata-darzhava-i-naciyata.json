            "field_type": 9,
            "level": 0,
            "sort_order": 6,
            "has_in_links": false,
            "is_orphaned": false,
            "text_markdown": "###  ДОПЪЛНИТЕЛНА РАЗПОРЕДБА",
            "children": [
                {
                    "path": "ДОПЪЛНИТЕЛНАРАЗПОРЕДБА/§1",
                    "p_id": 7064141,
                    "caption": "§ 1.",
                    "node_type": "transitional_paragraph",
                    "type": 11,
                    "field_type": 9,
