            "text_markdown": "### ЗАКОН за амнистия и връщане на отнети имущества",
            "children": []
        },
        {
            "path": "ПУБЛ_ИНФО",
            "p_id": 3773227,
            "caption": null,
            "node_type": "publication_info",
            "type": 0,
            "field_type": 2,
            "level": 0,
            "sort_order": 14,
            "has_in_links": false,
            "is_orphaned": true,
            "text_markdown": "Обн., ДВ, бр. 1 от 4.01.1991 г., попр., бр. 21 от 15.03.1991 г., изм., бр. 62 от 5.08.1997 г., доп., бр. 9 от 1.02.2000 г., в сила от 1.02.2000 г., бр. 34 от 25.04.2000 г.",
            "children": []
        }
    ]
